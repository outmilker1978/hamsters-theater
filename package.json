{
  "name": "tv-hamsters",
  "version": "1.7.7",
  "description": "TV Hamsters — смотрите видео вместе с голосовым чатом, видеочатом и рацией",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/index.js",
    "prebuild": "node -e \"var f=require('fs'),p='dist';if(f.existsSync(p)){f.readdirSync(p).filter(x=>x.endsWith('.exe')).forEach(x=>{f.mkdirSync(p+'/Archive',{recursive:true});f.renameSync(p+'/'+x,p+'/Archive/'+x)})}\"",
    "build": "electron-builder --win --x64",
    "build-portable": "electron-builder --prepackaged dist/win-unpacked --win portable"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "nat-upnp": "^1.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.tvhamsters.app",
    "productName": "TV Hamsters",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "includeSubNodeModules": false,
    "files": [
      "**/*",
      "!node_modules/electron-builder${/*}",
      "!node_modules/app-builder-bin${/*}",
      "!node_modules/7zip-bin${/*}",
      "!node_modules/electron${/*}"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "sign": false
    },
    "portable": {
      "artifactName": "TV.Hamsters.${version}.exe"
    }
  }
}
